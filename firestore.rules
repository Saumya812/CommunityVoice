rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /cases/{caseId} {
      allow read, write: if false;
    }
    match /resources/{resourceId} {
      allow read, write: if false;
    }
    match /allocations/{allocId} {
      allow read, write: if false;
    }
  }
}